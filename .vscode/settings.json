{
    "python.defaultInterpreterPath": "./.venv/bin/python",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.rulers": [100]
    },
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "python.analysis.extraPaths": [
        "./lib/activations",
        "./lib/explanations",
        "./lib/finetune_simulator",
        "./lib/frames",
        "./lib/lens",
        "./lib/neurondb",
        "./lib/util",
        "./project/docent",
        "./project/elicit",
        "./project/expgen",
        "./project/monitor",
        "./project/steering"
    ]
}
