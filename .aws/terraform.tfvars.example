# AWS Configuration
aws_region = "us-east-1"

# Environment Configuration
environment  = "dev"
project_name = "docent"

# Database Configuration
db_username = "docent"
db_password = "your-secure-password-here"

# App Runner Configuration
app_runner_cpu    = 1024  # 256, 512, 1024, 2048, 4096
app_runner_memory = 2048  # 512, 1024, 2048, 3072, 4096, 6144, 8192, 10240, 12288

# ECS Configuration
ecs_cpu    = 512   # 256, 512, 1024, 2048, 4096
ecs_memory = 1024  # 512, 1024, 2048, 3072, 4096, 5120, 6144, 7168, 8192

# Worker Configuration
worker_desired_count = 2
