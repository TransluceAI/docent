# LLM provider configuration.
# Defaults use DeepSeek. To use another OpenAI-compatible endpoint, set:
# DOCENT_LLM_PROVIDER=custom
# DOCENT_LLM_BASE_URL=https://your-provider.example/v1
DOCENT_LLM_PROVIDER=deepseek
DOCENT_LLM_BASE_URL=https://api.deepseek.com
DOCENT_LLM_API_KEY=<KEY>
DOCENT_LLM_FLASH_MODEL=deepseek-v4-flash
DOCENT_LLM_PRO_MODEL=deepseek-v4-pro
DOCENT_LLM_CONTEXT_WINDOW=1000000

# Embedding provider configuration.
# Defaults use OpenAI text-embedding-3-small with 512 dimensions.
# To reuse a custom OpenAI-compatible local endpoint for embeddings, set:
# DOCENT_LLM_PROVIDER=custom
# DOCENT_LLM_BASE_URL=http://localhost:8000/v1
# DOCENT_LLM_API_KEY=dummy-if-your-local-server-does-not-check-auth
DOCENT_EMBEDDING_BASE_URL=
DOCENT_EMBEDDING_API_KEY=
DOCENT_EMBEDDING_MODEL=text-embedding-3-small
DOCENT_EMBEDDING_DIMENSIONS=512

# Optional Hodoscope-only embedding overrides. Use these when the native
# Hodoscope map should use a local embedding model without changing Docent's
# existing transcript embedding table, which is fixed at 512 dimensions.
DOCENT_HODOSCOPE_EMBEDDING_MODEL=
DOCENT_HODOSCOPE_EMBEDDING_DIMENSIONS=
DOCENT_HODOSCOPE_EMBEDDING_BASE_URL=
DOCENT_HODOSCOPE_EMBEDDING_API_KEY=

# Optional per-feature model overrides. Leave blank to inherit FLASH/PRO.
DOCENT_LLM_CHAT_MODEL=
DOCENT_LLM_JUDGE_MODEL=
DOCENT_LLM_JUDGE_FALLBACK_MODEL=
DOCENT_LLM_SUMMARIZE_AGENT_ACTIONS_MODEL=
DOCENT_LLM_GROUP_ACTIONS_MODEL=
DOCENT_LLM_OBSERVATIONS_MODEL=
DOCENT_LLM_SEARCH_MODEL=
DOCENT_LLM_REFINE_MODEL=
DOCENT_LLM_REFINEMENT_MESSAGE_MODEL=
DOCENT_LLM_CLUSTER_MODEL=
DOCENT_LLM_CLUSTER_ASSIGN_MODEL=
DOCENT_LLM_CLUSTER_ASSIGN_STRONG_MODEL=
DOCENT_LLM_GENERATE_QUERIES_MODEL=
DOCENT_LLM_SUMMARIZE_INTENDED_SOLUTION_MODEL=

# Backward-compatible DeepSeek key alias. DOCENT_LLM_API_KEY takes precedence.
DEEPSEEK_API_KEY=
LLM_CACHE_PATH=

DOCENT_PG_USER=docent_user
DOCENT_PG_PASSWORD=docent_password
DOCENT_PG_HOST=localhost
DOCENT_PG_PORT=5432
DOCENT_PG_DATABASE=docent_db

DOCENT_REDIS_HOST=localhost
DOCENT_REDIS_PORT=6379
DOCENT_REDIS_USER=
DOCENT_REDIS_PASSWORD=
DOCENT_REDIS_TLS=

DOCENT_CORS_ORIGINS=

DEPLOYMENT_ID=
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_API_HOST=
